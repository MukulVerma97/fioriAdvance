<core:FragmentDefinition xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog title="Select an Employee" contentWidth="700px" contentHeight="400px" resizable="true" draggable="true">
        <subHeader>
            <Toolbar>
                <SearchField placeholder="Search employee..." liveChange="onFragmentSearch" width="100%" />
            </Toolbar>
        </subHeader>

        <Table items="{/Employees}" id="fragEmpTable">
            <columns>
                <Column width="5rem">
                    <Text text="ID" />
                </Column>
                <Column width="10rem">
                    <Text text="Name" />
                </Column>
                <Column width="8rem">
                    <Text text="Title" />
                </Column>
                <Column width="7rem">
                    <Text text="City" />
                </Column>
                <Column width="6rem">
                    <Text text="Country" />
                </Column>
                <Column width="8rem">
                    <Text text="Phone" />
                </Column>
            </columns>

            <items>
                <ColumnListItem type="Active" press="onPressFragRow">
                    <cells>
                        <ObjectIdentifier title="{EmployeeID}" />
                        <Text text="{= ${TitleOfCourtesy} + ' ' + ${FirstName} + ' ' + ${LastName}}" />
                        <Text text="{Title}" />
                        <Text text="{City}" />
                        <ObjectStatus text="{Country}" state="{path:'Country', formatter:'.f.countryColor'}" />
                        <Text text="{HomePhone}" />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>

        <endButton>
            <Button text="Close" icon="sap-icon://decline" press="onDialogClose" />
        </endButton>
    </Dialog>

</core:FragmentDefinition>