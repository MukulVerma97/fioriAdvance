<mvc:View xmlns:cards="sap.f.cards" controllerName="fiori2904.controller.View3"
     xmlns:mvc="sap.ui.core.mvc"
     xmlns="sap.m"
     xmlns:f="sap.ui.layout.form"
     xmlns:core="sap.ui.core">
     <Page id="page3" title="{i18n>titleOrderEntry}" showNavButton="true" navButtonPress="onNavBack">
          <content>
               <!-- Order Entry Header -->
               <ObjectHeader title="Order Entry Form" number="New" numberUnit="Order" backgroundDesign="Solid"
                    icon="sap-icon://create-form">
                    <attributes>
                         <ObjectAttribute title="Module" text="Sales Order Entry" />
                         <ObjectAttribute title="System" text="FIORI KPI ERP" />
                    </attributes>
                    <statuses>
                         <ObjectStatus text="Draft" state="Warning" />
                    </statuses>
               </ObjectHeader>

               <IconTabBar expandable="false" stretchContentHeight="false">
                    <items>
                         <!-- General Info Tab -->
                         <IconTabFilter icon="sap-icon://information" text="General Info">
                              <f:SimpleForm title="Order Information" editable="true" layout="ResponsiveGridLayout"
                                   labelSpanL="3" labelSpanM="3" emptySpanL="1" emptySpanM="1" columnsL="2" columnsM="1">
                                   <f:content>
                                        <core:Title text="Employee Assignment" />
                                        <Label text="Assigned Employee" required="true" />
                                        <Select items="{/Employees}" id="empSelect" change="onEmployeeSelect">
                                             <items>
                                                  <core:Item text="{= ${FirstName} + ' ' + ${LastName}}" key="{EmployeeID}" />
                                             </items>
                                        </Select>

                                        <Label text="Employee Title" />
                                        <Input id="empTitleField" enabled="false" value="" placeholder="Auto-filled on employee selection" />

                                        <core:Title text="Customer Assignment" />
                                        <Label text="Customer" required="true" />
                                        <ComboBox items="{/Customers}" id="customerCombo" placeholder="Select Customer...">
                                             <items>
                                                  <core:Item text="{CompanyName}" key="{CustomerID}" />
                                             </items>
                                        </ComboBox>
                                   </f:content>
                              </f:SimpleForm>
                         </IconTabFilter>

                         <!-- Order Details Tab -->
                         <IconTabFilter icon="sap-icon://sales-order" text="Order Details">
                              <f:SimpleForm title="Product Selection" editable="true" layout="ResponsiveGridLayout"
                                   labelSpanL="3" labelSpanM="3" emptySpanL="1" emptySpanM="1" columnsL="2" columnsM="1">
                                   <f:content>
                                        <core:Title text="Products" />
                                        <Label text="Select Products" required="true" />
                                        <MultiComboBox items="{/Products}" showSelectAll="true" id="mlcb" selectionFinish="onSelectionMCB">
                                             <items>
                                                  <core:Item text="{ProductName}" key="{ProductID}" />
                                             </items>
                                        </MultiComboBox>

                                        <core:Title text="Shipping" />
                                        <Label text="Ship Address" />
                                        <ComboBox items="{/Customers}" id="combo" selectionChange="onSelectionCombo" placeholder="Select shipping address...">
                                             <items>
                                                  <core:Item text="{= ${Address} + ', ' + ${City} + ', ' + ${Country}}" key="{CustomerID}" />
                                             </items>
                                        </ComboBox>

                                        <Label text="Ship City" />
                                        <Input id="shipCity" enabled="false" value="" placeholder="Auto-filled from address" />

                                        <Label text="Ship Country" />
                                        <Input id="shipCountry" enabled="false" value="" placeholder="Auto-filled from address" />
                                   </f:content>
                              </f:SimpleForm>
                         </IconTabFilter>

                         <!-- Country Preference Tab -->
                         <IconTabFilter icon="sap-icon://world" text="Preferences">
                              <f:SimpleForm title="Preferences" editable="true" layout="ResponsiveGridLayout"
                                   labelSpanL="3" labelSpanM="3" emptySpanL="1" emptySpanM="1" columnsL="2" columnsM="1">
                                   <f:content>
                                        <core:Title text="Preferred Country" />
                                        <Label text="Country" />
                                        <RadioButtonGroup buttons="{countryModel>/Countries}" columns="3" selectedIndex="-1" id="countryRadio">
                                             <buttons>
                                                  <RadioButton text="{countryModel>Country}" />
                                             </buttons>
                                        </RadioButtonGroup>

                                        <core:Title text="Additional Notes" />
                                        <Label text="Order Notes" />
                                        <TextArea id="orderNotes" rows="4" placeholder="Enter any special instructions..." growing="true" />
                                   </f:content>
                              </f:SimpleForm>
                         </IconTabFilter>
                    </items>
               </IconTabBar>

               <FlexBox justifyContent="Center" wrap="Wrap" class="sapUiMediumMarginTop sapUiSmallMarginBottom">
                    <Button text="Submit Order" icon="sap-icon://accept" type="Emphasized" press="onSimpleForm" class="sapUiSmallMarginEnd sapUiSmallMarginBottom" />
                    <Button text="Reset Form" icon="sap-icon://reset" type="Reject" press="onResetForm" class="sapUiSmallMarginBottom" />
               </FlexBox>
          </content>

          <footer>
               <Bar>
                    <contentLeft>
                         <Button text="Dashboard" icon="sap-icon://home" press="onNavBack" />
                    </contentLeft>
                    <contentRight>
                         <Button text="Products" icon="sap-icon://product" press="onProductPress" type="Emphasized" />
                    </contentRight>
               </Bar>
          </footer>
     </Page>
</mvc:View>