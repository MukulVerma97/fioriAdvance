<mvc:View controllerName="fiori2904.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page id="page" title="{i18n>title}" class="dashboardPage">
        <content>
            <!-- Quick Navigation Toolbar -->
            <Toolbar class="quickNavToolbar">
                <ToolbarSpacer />
                <Button text="Employees" icon="sap-icon://employee" type="Transparent" press="onNavSelf" />
                <Button text="Products" icon="sap-icon://product" type="Transparent" press="onNavProducts" />
                <Button text="Orders" icon="sap-icon://sales-order" type="Transparent" press="onNavOrders" />
                <Button text="Customers" icon="sap-icon://customer" type="Transparent" press="onNavCustomers" />
                <Button text="Order Entry" icon="sap-icon://create-form" type="Transparent" press="onNavOrderEntry" />
            </Toolbar>

            <!-- KPI Tiles Section -->
            <FlexBox direction="Row" wrap="Wrap" class="kpiTileContainer" justifyContent="Start">
                <VBox class="kpiTile kpiTileEmployees">
                    <core:Icon src="sap-icon://employee" class="kpiTileIcon" />
                    <Text text="{kpiModel>/employeeCount}" class="kpiTileValue" />
                    <Text text="EMPLOYEES" class="kpiTileLabel" />
                </VBox>
                <VBox class="kpiTile kpiTileProducts">
                    <core:Icon src="sap-icon://product" class="kpiTileIcon" />
                    <Text text="{kpiModel>/productCount}" class="kpiTileValue" />
                    <Text text="PRODUCTS" class="kpiTileLabel" />
                </VBox>
                <VBox class="kpiTile kpiTileOrders">
                    <core:Icon src="sap-icon://sales-order" class="kpiTileIcon" />
                    <Text text="{kpiModel>/orderCount}" class="kpiTileValue" />
                    <Text text="ORDERS" class="kpiTileLabel" />
                </VBox>
                <VBox class="kpiTile kpiTileCustomers">
                    <core:Icon src="sap-icon://customer" class="kpiTileIcon" />
                    <Text text="{kpiModel>/customerCount}" class="kpiTileValue" />
                    <Text text="CUSTOMERS" class="kpiTileLabel" />
                </VBox>
            </FlexBox>

            <!-- Employee Table with Search and Filtering -->
            <IconTabBar id="empCountryTabs" select="onTabSelect" expandable="false">
                <items>
                    <IconTabFilter text="All" key="All" icon="sap-icon://world" count="{kpiModel>/employeeCount}" />
                    <IconTabFilter text="USA" key="USA" icon="sap-icon://flag" iconColor="Positive" />
                    <IconTabFilter text="UK" key="UK" icon="sap-icon://flag" iconColor="Critical" />
                </items>
            </IconTabBar>

            <ScrollContainer horizontal="true" vertical="false" height="auto" width="100%">
                <Table items="{/Employees}" mode="SingleSelectLeft" id="idTable" growing="true" growingThreshold="20"
                    autoPopinMode="true" fixedLayout="false">
                    <headerToolbar>
                        <Toolbar>
                            <Title text="{i18n>employeeListTitle}" />
                            <ToolbarSpacer />
                            <SearchField id="empSearchField" placeholder="Search by Name or Country..."
                                liveChange="onSearch" width="250px" />
                            <Button text="Get Details" icon="sap-icon://detail-view" press="getSelectedEmployeeData" type="Transparent" />
                        </Toolbar>
                    </headerToolbar>
                    <columns>
                        <Column width="4rem" importance="High">
                            <Text text="{i18n>colEmployeeID}" />
                        </Column>
                        <Column width="9rem" importance="High">
                            <Text text="{i18n>colName}" />
                        </Column>
                        <Column width="7rem" importance="Medium" demandPopin="true" minScreenWidth="Tablet" popinDisplay="Inline">
                            <Text text="{i18n>colTitle}" />
                        </Column>
                        <Column width="7rem" importance="Medium" demandPopin="true" minScreenWidth="Tablet" popinDisplay="Inline">
                            <Text text="{i18n>colBirthDate}" />
                        </Column>
                        <Column width="7rem" importance="Low" demandPopin="true" minScreenWidth="Desktop" popinDisplay="Inline">
                            <Text text="{i18n>colHireDate}" />
                        </Column>
                        <Column width="9rem" importance="Low" demandPopin="true" minScreenWidth="Desktop" popinDisplay="Inline">
                            <Text text="{i18n>colAddress}" />
                        </Column>
                        <Column width="5rem" importance="Medium" demandPopin="true" minScreenWidth="Tablet" popinDisplay="Inline">
                            <Text text="{i18n>colCity}" />
                        </Column>
                        <Column width="5rem" importance="High">
                            <Text text="{i18n>colCountry}" />
                        </Column>
                        <Column width="4rem" importance="Low" demandPopin="true" minScreenWidth="Desktop" popinDisplay="Inline">
                            <Text text="{i18n>colPhoto}" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem type="Navigation" press="onPressRow">
                            <cells>
                                <ObjectIdentifier title="{EmployeeID}" />
                                <Text text="{= ${TitleOfCourtesy} + ' ' + ${FirstName} + ' ' + ${LastName}}" />
                                <Text text="{Title}" />
                                <Text text="{path:'BirthDate', formatter:'.f.formatDate'}" />
                                <Text text="{path:'HireDate', formatter:'.f.formatDate'}" />
                                <Text text="{Address}" />
                                <Text text="{City}" />
                                <ObjectStatus text="{Country}" state="{path:'Country', formatter:'.f.countryColor'}" />
                                <Image src="{= 'https://randomuser.me/api/portraits/men/' + ${EmployeeID} + '.jpg' }"
                                    width="40px" height="40px" class="empPhotoSmall" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </ScrollContainer>
        </content>
    </Page>
</mvc:View>